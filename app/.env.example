# Deployment environment: "prod" | "dev". Local dev MUST set "dev".
# In "prod", the Cognito IDs below are required or the app refuses to start.
ENVIRONMENT=dev

# Cloudflare Realtime SFU
CF_TELEOP_APP_ID=your-app-id-here
CF_TELEOP_APP_SECRET=your-app-secret-here

# Cloudflare TURN service (dashboard: Realtime → TURN → create key).
# Optional — unset means STUN-only, which fails for clients on networks
# that block UDP (CGNAT, corporate/mobile networks).
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# LiveKit (alternative backend, selected per session via transport="livekit").
# Optional — unset means LiveKit sessions are refused; Cloudflare still works.
# URL is dialed by clients; key/secret mint JWTs server-side only.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Cognito (operator auth). Values come from terraform outputs
# cognito_user_pool_id / cognito_client_id. The broker only verifies
# tokens — sign-in happens between the SPA and Cognito directly.
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Database (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./teleop.db

# Server
HOST=0.0.0.0
PORT=8450
